---
import content from "../data/content.json";
const { about } = content;
---

<section id="about" class="border-t border-warm-gray bg-card px-6 py-16 md:py-20">
  <div class="mx-auto max-w-4xl">
    <h2 class="font-serif text-4xl font-semibold text-center text-warm-black">
      {about.heading}
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-warm-black/60 text-lg">
      {about.subheading}
    </p>
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {about.team.map((person, i) => (
        <div class="rounded-xl border border-warm-gray bg-warm-white p-6 shadow-sm">
          <div class="flex items-center gap-4">
            <div class:list={[
              "flex h-14 w-14 items-center justify-center rounded-full font-serif text-lg font-semibold text-warm-white shadow-sm",
              i === 0 ? "bg-crail" : "bg-sage"
            ]}>
              {person.initials}
            </div>
            <div>
              <h3 class="font-serif text-xl font-medium text-warm-black">{person.name}</h3>
              <p class="text-sm font-medium text-crail">{person.role}</p>
            </div>
          </div>
          <p class="mt-4 text-base leading-relaxed text-warm-black/60">
            {person.bio}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
