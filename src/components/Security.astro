---
import content from "../data/content.json";
const { security } = content;
---

<section id="security" class="border-t border-warm-gray px-6 py-14 md:py-16">
  <div class="mx-auto flex max-w-3xl flex-col items-center gap-3 text-center">
    <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-sage/15 text-sage">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
    </div>
    <h2 class="font-serif text-3xl font-semibold text-warm-black">
      {security.heading}
    </h2>
    <p class="max-w-2xl text-lg leading-relaxed text-warm-black/60">
      {security.subheading}
    </p>
  </div>
</section>
