---
const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: "Client & Lead Management",
    description:
      "Capture leads, onboard new clients, and nurture prospects without manual follow-up.",
    examples: [
      "Automated client onboarding workflows",
      "Lead routing & CRM updates",
      "Follow-up email sequences",
      "Appointment scheduling",
    ],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>`,
    title: "Billing & Financial Ops",
    description:
      "Automate invoicing, payment tracking, and financial data sync across your tools.",
    examples: [
      "Invoice & payment automation",
      "Expense matching to jobs",
      "AP/AR sync across systems",
    ],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>`,
    title: "Documents & Data Collection",
    description:
      "Collect, organize, and extract data from documents and forms automatically.",
    examples: [
      "Document collection & filing",
      "AI-powered form processing",
      "Email sorting & routing",
    ],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="m19 9-5 5-4-4-3 3"/></svg>`,
    title: "Reporting & Analytics",
    description:
      "Consolidate data from multiple tools into dashboards and automated reports.",
    examples: [
      "Automated reporting & dashboards",
      "KPI alerts & anomaly detection",
      "Cross-system data consolidation",
    ],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>`,
    title: "Internal Ops & Productivity",
    description:
      "Keep your team organized with automated task creation, notifications, and provisioning.",
    examples: [
      "Task assignment & project kickoffs",
      "Internal alerts & notifications",
      "Account & access provisioning",
    ],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>`,
    title: "Inventory & Supply Chain",
    description:
      "Sync inventory levels, track purchase orders, and get alerts before stock runs out.",
    examples: [
      "Inventory syncing & low-stock alerts",
      "Purchase order tracking",
    ],
  },
];
---

<section id="services" class="border-t border-warm-gray bg-card px-6 py-16 md:py-20">
  <div class="mx-auto max-w-6xl">
    <h2 class="font-serif text-3xl font-semibold text-center text-warm-black">
      What we automate
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-warm-black/60">
      Six areas where most small businesses lose the most time.
    </p>
    <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <div class="group rounded-xl border border-warm-gray bg-warm-white p-6 transition-all hover:border-crail/30 hover:shadow-sm">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-crail/10 text-crail">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="mt-4 font-serif text-lg font-medium text-warm-black">
            {service.title}
          </h3>
          <p class="mt-1.5 text-sm leading-relaxed text-warm-black/60">
            {service.description}
          </p>
          <ul class="mt-3 space-y-1">
            {service.examples.map((example) => (
              <li class="flex items-start gap-2 text-sm text-warm-black/50">
                <span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-crail/40" />
                {example}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
