---
interface Workflow {
  name: string;
  description: string;
}

interface Props {
  slug: string;
  title: string;
  problem: string;
  solution: string;
  workflows: Workflow[];
  tools: string[];
  icon: string;
  index: number;
}

const { slug, title, problem, solution, workflows, tools, icon, index } = Astro.props;
const isAlt = index % 2 === 1;
---

<section id={slug} class:list={["px-6 py-16 md:py-20 border-t border-warm-gray", isAlt ? "bg-card" : "bg-warm-white"]}>
  <div class="mx-auto max-w-4xl">
    <!-- Header -->
    <div class="flex items-start gap-4">
      <div class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-lg bg-crail/10 text-crail">
        <Fragment set:html={icon} />
      </div>
      <h2 class="font-serif text-3xl font-semibold text-warm-black">{title}</h2>
    </div>

    <!-- Problem & Solution -->
    <div class="mt-8 grid gap-6 md:grid-cols-2">
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-warm-black/40">The Problem</h3>
        <p class="mt-2 text-base leading-relaxed text-warm-black/70">{problem}</p>
      </div>
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-warm-black/40">Our Solution</h3>
        <p class="mt-2 text-base leading-relaxed text-warm-black/70">{solution}</p>
      </div>
    </div>

    <!-- Example Workflows -->
    <div class="mt-10">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-warm-black/40">Example Workflows</h3>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {workflows.map((wf) => (
          <div class="rounded-lg border border-warm-gray bg-warm-white p-5">
            <h4 class="font-serif text-lg font-medium text-warm-black">{wf.name}</h4>
            <p class="mt-1.5 text-sm leading-relaxed text-warm-black/60">{wf.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Tools Used -->
    <div class="mt-8">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-warm-black/40">Tools We Use</h3>
      <div class="mt-3 flex flex-wrap gap-2">
        {tools.map((tool) => (
          <span class="rounded-full border border-warm-gray bg-warm-white px-3 py-1 text-sm text-warm-black/70">
            {tool}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
