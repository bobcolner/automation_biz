---
---

<section id="contact" class="contact-bg relative overflow-hidden px-6 py-16 md:py-20">
  <!-- geometric pattern -->
  <svg
    class="pointer-events-none absolute inset-0 h-full w-full"
    viewBox="0 0 1200 500"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
  >
    <circle cx="100" cy="100" r="200" stroke="rgba(193,95,60,0.10)" stroke-width="1" />
    <circle cx="100" cy="100" r="140" stroke="rgba(193,95,60,0.07)" stroke-width="1" />
    <circle cx="1100" cy="400" r="180" stroke="rgba(107,127,107,0.10)" stroke-width="1" />
    <circle cx="1100" cy="400" r="120" stroke="rgba(107,127,107,0.07)" stroke-width="1" />
    <line x1="300" y1="0" x2="900" y2="500" stroke="rgba(255,255,255,0.03)" stroke-width="1" />
  </svg>

  <div class="relative mx-auto max-w-xl">
    <h2 class="font-serif text-3xl font-semibold text-center text-warm-white">
      Let's talk about what you can automate
    </h2>
    <p class="mx-auto mt-3 max-w-md text-center text-warm-white/50">
      Tell us a bit about your business and we'll come back with ideas.
    </p>

    <form
      id="contact-form"
      name="contact"
      method="POST"
      data-netlify="true"
      class="mt-8 space-y-4"
    >
      <input type="hidden" name="form-name" value="contact" />
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="name" class="block text-sm font-medium text-warm-white/70">
            Name <span class="text-crail">*</span>
          </label>
          <input
            type="text"
            name="name"
            id="name"
            required
            class="mt-1 w-full rounded-lg border border-white/10 bg-white/5 px-4 py-2.5 text-warm-white placeholder:text-warm-white/25 focus:border-crail focus:outline-none focus:ring-1 focus:ring-crail"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-warm-white/70">
            Email <span class="text-crail">*</span>
          </label>
          <input
            type="email"
            name="email"
            id="email"
            required
            class="mt-1 w-full rounded-lg border border-white/10 bg-white/5 px-4 py-2.5 text-warm-white placeholder:text-warm-white/25 focus:border-crail focus:outline-none focus:ring-1 focus:ring-crail"
            placeholder="you@company.com"
          />
        </div>
      </div>

      <div>
        <label for="company" class="block text-sm font-medium text-warm-white/70">
          Company
        </label>
        <input
          type="text"
          name="company"
          id="company"
          class="mt-1 w-full rounded-lg border border-white/10 bg-white/5 px-4 py-2.5 text-warm-white placeholder:text-warm-white/25 focus:border-crail focus:outline-none focus:ring-1 focus:ring-crail"
          placeholder="Your company (optional)"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-warm-white/70">
          What are you looking to automate?
        </label>
        <textarea
          name="message"
          id="message"
          rows="3"
          class="mt-1 w-full rounded-lg border border-white/10 bg-white/5 px-4 py-2.5 text-warm-white placeholder:text-warm-white/25 focus:border-crail focus:outline-none focus:ring-1 focus:ring-crail resize-none"
          placeholder="Tell us about the manual processes eating up your time (optional)"
        ></textarea>
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="w-full rounded-full bg-crail px-8 py-3 text-sm font-medium text-warm-white transition-all hover:bg-crail-hover hover:shadow-lg hover:shadow-crail/20"
      >
        Send message
      </button>
    </form>

    <!-- success message (hidden by default) -->
    <div id="success-msg" class="mt-8 hidden text-center">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-crail/15">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-crail"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <p class="font-serif text-xl font-medium text-warm-white">Message received</p>
      <p class="mt-2 text-sm text-warm-white/50">We'll get back to you within one business day.</p>
    </div>

    <!-- error message (hidden by default) -->
    <div id="error-msg" class="mt-4 hidden text-center text-sm text-crail">
      Something went wrong. Please try again or email us directly.
    </div>

    <p id="privacy-note" class="mt-4 text-center text-xs text-warm-white/30">
      We'll only use your info to follow up on your inquiry. No spam, ever.
    </p>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const successMsg = document.getElementById("success-msg")!;
  const errorMsg = document.getElementById("error-msg")!;
  const privacyNote = document.getElementById("privacy-note")!;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    btn.textContent = "Sending...";
    btn.disabled = true;
    errorMsg.classList.add("hidden");

    try {
      const response = await fetch("/", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: new URLSearchParams(new FormData(form) as any).toString(),
      });

      if (response.ok) {
        form.classList.add("hidden");
        privacyNote.classList.add("hidden");
        successMsg.classList.remove("hidden");
      } else {
        throw new Error("Form submission failed");
      }
    } catch {
      btn.textContent = "Send message";
      btn.disabled = false;
      errorMsg.classList.remove("hidden");
    }
  });
</script>

<style>
  .contact-bg {
    background-color: var(--color-warm-black);
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 80px 80px;
  }
</style>
