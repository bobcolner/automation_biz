---
---

<section class="hero-bg relative overflow-hidden px-6 pt-28 pb-20 md:pt-36 md:pb-24">
  <!-- geometric arcs and lines -->
  <svg
    class="pointer-events-none absolute inset-0 h-full w-full"
    viewBox="0 0 1200 600"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
  >
    <!-- large concentric arcs, upper right -->
    <circle cx="900" cy="80" r="320" stroke="rgba(193,95,60,0.18)" stroke-width="1" />
    <circle cx="900" cy="80" r="240" stroke="rgba(193,95,60,0.14)" stroke-width="1" />
    <circle cx="900" cy="80" r="160" stroke="rgba(193,95,60,0.10)" stroke-width="1" />

    <!-- arcs, lower left -->
    <circle cx="200" cy="550" r="280" stroke="rgba(107,127,107,0.16)" stroke-width="1" />
    <circle cx="200" cy="550" r="200" stroke="rgba(107,127,107,0.12)" stroke-width="1" />
    <circle cx="200" cy="550" r="120" stroke="rgba(107,127,107,0.08)" stroke-width="1" />

    <!-- crossing diagonals -->
    <line x1="0" y1="600" x2="700" y2="0" stroke="rgba(255,255,255,0.06)" stroke-width="1" />
    <line x1="500" y1="600" x2="1200" y2="0" stroke="rgba(255,255,255,0.06)" stroke-width="1" />
    <line x1="100" y1="0" x2="1100" y2="600" stroke="rgba(255,255,255,0.04)" stroke-width="1" />

    <!-- node dots -->
    <circle cx="600" cy="90" r="3" fill="rgba(193,95,60,0.35)" />
    <circle cx="300" cy="400" r="3" fill="rgba(193,95,60,0.30)" />
    <circle cx="900" cy="350" r="2.5" fill="rgba(107,127,107,0.30)" />
    <circle cx="1000" cy="180" r="2.5" fill="rgba(193,95,60,0.28)" />
    <circle cx="150" cy="200" r="2.5" fill="rgba(107,127,107,0.25)" />
    <circle cx="750" cy="500" r="2.5" fill="rgba(193,95,60,0.22)" />
    <circle cx="450" cy="250" r="2" fill="rgba(107,127,107,0.20)" />
    <circle cx="1050" cy="480" r="2" fill="rgba(193,95,60,0.20)" />
  </svg>

  <!-- soft radial glow -->
  <div class="pointer-events-none absolute -top-20 left-1/2 h-[500px] w-[800px] -translate-x-1/2 rounded-full bg-crail/10 blur-3xl"></div>

  <div class="relative mx-auto max-w-3xl text-center">
    <p class="mb-4 text-sm font-medium tracking-widest uppercase text-crail">
      Workflow Partners
    </p>
    <h1 class="font-serif text-4xl font-semibold leading-tight tracking-tight text-warm-white md:text-5xl lg:text-6xl">
      Stop doing work<br />a machine should do
    </h1>
    <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-warm-white/60">
      We help small and mid-size businesses eliminate repetitive tasks, connect
      their tools, and build automations that actually stick.
    </p>
    <div class="mt-8">
      <a
        href="#contact"
        class="hero-cta inline-block rounded-full bg-crail px-9 py-4 text-base font-medium text-warm-white transition-all hover:bg-crail-hover hover:shadow-lg hover:shadow-crail/20"
      >
        Get a free automation audit
      </a>
    </div>
    <p class="mt-6 text-sm text-warm-white/35">No commitment. We'll show you what's possible.</p>
  </div>
</section>

<style>
  .hero-bg {
    background-color: var(--color-warm-black);
    background-image:
      linear-gradient(rgba(255,255,255,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 80px 80px;
  }
  .hero-cta {
    box-shadow: 0 0 20px rgba(193,95,60,0.25), 0 0 60px rgba(193,95,60,0.08);
  }
  .hero-cta:hover {
    box-shadow: 0 0 25px rgba(193,95,60,0.35), 0 0 80px rgba(193,95,60,0.12);
  }
</style>
