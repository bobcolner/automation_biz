---
import content from "../data/content.json";
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import UseCaseDetail from "../components/UseCaseDetail.astro";
import Footer from "../components/Footer.astro";

const { useCases, business } = content;

const icons = [
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="m19 9-5 5-4-4-3 3"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>`,
];
---

<Layout title={`Use Cases — ${business.name}`} description="See how we automate client management, billing, documents, reporting, internal ops, and inventory for growing businesses.">
  <Nav />
  <main>
    <!-- Page Header -->
    <section class="bg-warm-black px-6 pt-32 pb-16 md:pb-20">
      <div class="mx-auto max-w-4xl text-center">
        <h1 class="font-serif text-4xl font-semibold text-warm-white md:text-5xl">
          {useCases.heading}
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-warm-white/60">
          {useCases.subheading}
        </p>
      </div>
    </section>

    <!-- Use Case Detail Sections -->
    {useCases.items.map((item, i) => (
      <UseCaseDetail
        slug={item.slug}
        title={item.title}
        problem={item.problem}
        solution={item.solution}
        workflows={item.workflows}
        tools={item.tools}
        icon={icons[i]}
        index={i}
      />
    ))}

    <!-- CTA Section -->
    <section class="bg-warm-black px-6 py-16 md:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="font-serif text-3xl font-semibold text-warm-white">
          Ready to automate?
        </h2>
        <p class="mt-3 text-lg text-warm-white/60">
          Tell us which workflows are slowing you down. We'll show you what's possible.
        </p>
        <a
          href="/#contact"
          class="mt-8 inline-block rounded-full bg-crail px-8 py-3 text-base font-medium text-warm-white transition-colors hover:bg-crail-hover"
        >
          Get a free automation audit
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
