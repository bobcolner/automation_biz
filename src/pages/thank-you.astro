---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Thank you — Workflow Partners">
  <Nav />
  <main class="flex min-h-[80vh] items-center justify-center bg-warm-black px-6">
    <div class="max-w-md text-center">
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-crail/15">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-crail"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <h1 class="font-serif text-3xl font-semibold text-warm-white">
        Message received
      </h1>
      <p class="mt-3 text-warm-white/50">
        Thanks for reaching out. We'll review your info and get back to you within one business day.
      </p>
      <a
        href="/"
        class="mt-8 inline-block rounded-full bg-crail px-7 py-3 text-sm font-medium text-warm-white transition-colors hover:bg-crail-hover"
      >
        Back to home
      </a>
    </div>
  </main>
  <Footer />
</Layout>
